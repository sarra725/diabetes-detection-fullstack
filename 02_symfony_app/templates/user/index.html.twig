{% extends 'basAdmin.html.twig' %}



{% block body %}
    <body class="app">
    {% include 'shared/_headerAdmin.html.twig' %}


    <div class="app-wrapper">

        <div class="app-content pt-3 p-md-3 p-lg-4">
            <div class="container-xl">
                <di class="row">
                    <div class="col col-lg-9">
                        <h1 class="app-page-title">Users</h1></div>

                    <!--//col--></di>
                <div class="app-card alert alert-dismissible shadow-sm mb-4 border-left-decoration" role="alert">

                    <a  style="color:#2a5b8d" href="{{ path('registration') }}"><i class="fa fa-user-plus" aria-hidden="true"></i> Create
                        new</a>
                    <table class="table">
                        <thead>
                        <tr>

                            <th>Email</th>
                            <th>Name</th>
                            <th>Roles</th>

                            <th>actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for user in users %}
                            <tr>

                                <td>{{ user.email }}</td>
                                <td>{{ user.name }}</td>
                                <td>
{% for role in user.roles %}
                                    {% if role== 'ROLE_ADMIN' %}

                                    Administrateur

                                        
                                    
                                    {% else %}
                                        User
                                    {% endif %}
                                    {% endfor %}
                                </td>
                                <td>

                                    {# {{ include('user/_delete_form.html.twig') }} #}
                                    <div class="row">
                                        <div class="col-2">
                                            <form method="post" action="{{ path('app_user_delete', {'id': user.id}) }}"
                                                  onsubmit="return confirm('Are you sure you want to delete this user?');">
                                                <input type="hidden" name="_token"
                                                       value="{{ csrf_token('delete' ~ user.id) }}">
                                                <button class="btn "><i class="fa fa-trash" aria-hidden="true"></i>
                                                </button>
                                            </form>
                                        </div>
                                        <div class="col-2">
                                            <button class="btn "  ><a class=""style="color:#2a5b8d"
                                                                    href="{{ path('app_user_edit', {'id': user.id}) }}"><i
                                                            class="fa fa-pencil" aria-hidden="true"></i></a>
                                            </button>

                                        </div>
                                    </div>
                                </td>
                            </tr>

                         
                        {% endfor %}
                        </tbody>
                    </table>


                </div><!--//app-content-->


            </div><!--//app-wrapper-->
        </div>
    </div>

    </body>

{% endblock %}
